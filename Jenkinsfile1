pipeline {
    agent any

    tools {
        nodejs 'node20'
    }

    environment {
        GIT_REPO           = 'https://github.com/vasukumgit/stack1.git'
        GIT_BRANCH         = 'main'
        APP_DIR            = 'graphic-design-tool-main/graphic-design-tool-main'
        BACKEND_DIR  = 'graphic-design-tool-main/Backend'
        FRONTEND_DIR = 'graphic-design-tool-main/Frontend'
        ARTIFACT_NAME      = 'graphic_app.tar.gz'
        S3_BUCKET          = 'vasu-terraform-state-us-east-2'
        AWS_DEFAULT_REGION = 'us-east-2'

        EC2_HOST           = '18.225.11.23'
        EC2_USER           = 'ubuntu'
        REMOTE_APP_DIR     = '/home/ubuntu/app'
        HEALTH_URL         = 'http://3.139.89.47:5050/health'
    }

    stages {
        stage('Checkout Code') {
            steps {
                git branch: "${GIT_BRANCH}", url: "${GIT_REPO}"
            }
        }

        stage('Install Dependencies') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh 'apt install nginx'
                    sh 'systemctl enable nginx'
                    sh 'npm install'

                }
            }
        }
         stage('Install Dependencies') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh 'npm install -g pm2'
                    sh 'curl -fsSL https://deb.nodesource.com/setup_20.x | bash - '
                    sh   'apt-get install -y nodejs'
                    sh 'npm install'

                }
            }
        }
        stage('Build App') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh 'npm run build'
                    sh 'systemctl restart nginx'
                }
            }
        }
        stage('Build App') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh 'node server.js'
                }
            }
        }
        stage('Run Tests') {
            steps {
                dir("${APP_DIR}") {
                    sh 'npm test'
                }
            }
        }

        stage('Package Artifact') {
            steps {
                sh "tar -czf ${ARTIFACT_NAME} -C ${APP_DIR} ."
            }
        }

        stage('Upload Artifact to S3') {
            steps {
                sh "aws s3 cp ${ARTIFACT_NAME} s3://${S3_BUCKET}/${ARTIFACT_NAME}"
            }
        }

        stage('Deploy to EC2') {
            steps {
                sshagent(credentials: ['ec2-ssh-key']) {
                    sh """
                        scp -o StrictHostKeyChecking=no ${ARTIFACT_NAME} ${EC2_USER}@${EC2_HOST}:/tmp/

                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} '
                            sudo mkdir -p ${REMOTE_APP_DIR}
                            sudo tar -xzf /tmp/${ARTIFACT_NAME} -C ${REMOTE_APP_DIR}
                            cd ${REMOTE_APP_DIR}
                            npm install --production
                            pm2 restart app || pm2 start server.js --name app
                        '
                    """
                }
            }
        }

        stage('Verify Health') {
            steps {
                sh """
                    sleep 15
                    curl -f ${HEALTH_URL}
                """
            }
        }

        stage('Publish Deployment Metric to CloudWatch') {
            steps {
                sh '''
                    aws cloudwatch put-metric-data \
                      --namespace "Jenkins/Deployments" \
                      --metric-name "DeploymentSuccess" \
                      --value 1 \
                      --unit Count \
                      --dimensions Environment=Production,Application=GraphicDesignTool
                '''
            }
        }
    }

    post {
        success {
            withCredentials([[
                $class: 'AmazonWebServicesCredentialsBinding',
                credentialsId: 'aws-creds'
            ]]) {
                sh '''
                    aws cloudwatch put-metric-data \
                      --namespace Jenkins/Deployments \
                      --metric-name DeploymentSuccess \
                      --value 1 \
                      --unit Count \
                      --dimensions Environment=Production,Application=GraphicDesignTool
                '''
            }
        }

        failure {
            script {
                try {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-creds'
                    ]]) {
                        sh '''
                            aws cloudwatch put-metric-data \
                              --namespace Jenkins/Deployments \
                              --metric-name DeploymentFailure \
                              --value 1 \
                              --unit Count \
                              --dimensions Environment=Production,Application=GraphicDesignTool
                        '''
                    }
                } catch (Exception e) {
                    echo "CloudWatch metric skipped: AWS credentials not configured"
                }
            }
        }
    }
}
