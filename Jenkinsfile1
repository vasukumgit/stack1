pipeline {
    agent any

    tools {
        nodejs 'node20'
    }

    options {
        skipDefaultCheckout(true)
        timestamps()
    }

    environment {
        GIT_REPO           = 'https://github.com/vasukumgit/stack1.git'
        GIT_BRANCH         = 'main'

        ROOT_DIR           = 'graphic-design-tool-main'
        BACKEND_DIR        = 'graphic-design-tool-main/Backend'
        FRONTEND_DIR       = 'graphic-design-tool-main/Frontend'

        ARTIFACT_NAME      = 'graphic_app.tar.gz'
        S3_BUCKET          = 'vasu-terraform-state-us-east-2'
        AWS_DEFAULT_REGION = 'us-east-2'

        EC2_HOST           = '18.225.11.23'
        EC2_USER           = 'ubuntu'
        REMOTE_APP_DIR     = '/home/ubuntu/app'

        HEALTH_URL         = 'http://18.225.11.23:5050/health'
    }

    stages {
        stage('Checkout Code') {
            steps {
                git branch: "${GIT_BRANCH}", url: "${GIT_REPO}"
            }
        }

        stage('Verify Project Structure') {
            steps {
                sh '''
                    echo "Workspace:"
                    pwd
                    echo "Repo files:"
                    ls -la
                    echo "Project structure:"
                    find . -maxdepth 4 -type f | sort | head -300
                    echo "package.json locations:"
                    find . -name package.json | sort || true
                '''
            }
        }

        stage('Validate Paths') {
            steps {
                sh '''
                    test -f "${BACKEND_DIR}/package.json" || { echo "Missing backend package.json at ${BACKEND_DIR}/package.json"; exit 1; }
                    test -f "${FRONTEND_DIR}/package.json" || { echo "Missing frontend package.json at ${FRONTEND_DIR}/package.json"; exit 1; }
                '''
            }
        }

        stage('Install Frontend Dependencies') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh 'npm install'
                }
            }
        }

        stage('Install Backend Dependencies') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh 'npm install'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh 'npm run build || echo "No frontend build script found, skipping"'
                }
            }
        }

        stage('Run Backend Tests') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh 'npm test || echo "No backend tests configured, skipping"'
                }
            }
        }

        stage('Run Frontend Tests') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh 'npm test || echo "No frontend tests configured, skipping"'
                }
            }
        }

        stage('Package Artifact') {
            steps {
                sh """
                    tar -czf ${ARTIFACT_NAME} -C ${ROOT_DIR} .
                    ls -lh ${ARTIFACT_NAME}
                """
            }
        }

        stage('Upload Artifact to S3') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    sh """
                        aws s3 cp ${ARTIFACT_NAME} s3://${S3_BUCKET}/${ARTIFACT_NAME}
                    """
                }
            }
        }

        stage('Deploy to EC2') {
            steps {
                sshagent(credentials: ['ec2-ssh-key']) {
                    sh """
                        scp -o StrictHostKeyChecking=no ${ARTIFACT_NAME} ${EC2_USER}@${EC2_HOST}:/tmp/

                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} '
                            set -e
                            mkdir -p ${REMOTE_APP_DIR}
                            rm -rf ${REMOTE_APP_DIR:?}/*
                            tar -xzf /tmp/${ARTIFACT_NAME} -C ${REMOTE_APP_DIR}

                            cd ${REMOTE_APP_DIR}/Backend
                            npm install --production

                            pm2 delete app || true
                            pm2 start server.js --name app
                            pm2 save

                            sudo systemctl restart nginx || true
                        '
                    """
                }
            }
        }

        stage('Verify Health') {
            steps {
                sh """
                    sleep 15
                    curl -f ${HEALTH_URL}
                """
            }
        }
    }

    post {
        success {
            script {
                try {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-creds'
                    ]]) {
                        sh '''
                            aws cloudwatch put-metric-data \
                              --namespace Jenkins/Deployments \
                              --metric-name DeploymentSuccess \
                              --value 1 \
                              --unit Count \
                              --dimensions Environment=Production,Application=GraphicDesignTool
                        '''
                    }
                } catch (Exception e) {
                    echo "CloudWatch success metric skipped: AWS credentials not configured"
                }
            }
        }

        failure {
            script {
                try {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-creds'
                    ]]) {
                        sh '''
                            aws cloudwatch put-metric-data \
                              --namespace Jenkins/Deployments \
                              --metric-name DeploymentFailure \
                              --value 1 \
                              --unit Count \
                              --dimensions Environment=Production,Application=GraphicDesignTool
                        '''
                    }
                } catch (Exception e) {
                    echo "CloudWatch failure metric skipped: AWS credentials not configured"
                }
            }
        }
    }
}
